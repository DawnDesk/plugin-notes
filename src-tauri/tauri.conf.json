{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DawnDesk Plugin Template",
  "version": "0.1.0",
  "identifier": "app.dawndesk.plugin-template",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DawnDesk Plugin Template",
        "width": 1100,
        "height": 760
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
